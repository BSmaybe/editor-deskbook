# PostgreSQL container credentials
POSTGRES_USER=deskbook
POSTGRES_PASSWORD=deskbook
POSTGRES_DB=deskbook

# Database connection (used by Go API)
DATABASE_URL=postgresql://deskbook:deskbook@postgres:5432/deskbook

# JWT secret (change in production)
SECRET_KEY=change-me-in-production

# Bootstrap admin (created on first start if no admin exists)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@deskbook.local
BOOTSTRAP_ADMIN_PASSWORD=admin123

# App mode: development | production
APP_ENV=development

# External port for the admin UI (default: 80)
# DESKBOOK_PORT=80
