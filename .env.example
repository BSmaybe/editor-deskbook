# Database connection (used by Go API)
DATABASE_URL=postgresql://deskbook:deskbook@postgres:5432/deskbook

# App mode: development | production
APP_ENV=development

# JWT / Auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Admin self-registration secret (leave empty to disable admin self-registration)
ADMIN_REGISTER_SECRET=

# Static files directory (floor plan uploads)
STATIC_DIR=/app/static

# PostgreSQL container credentials (used by the postgres service)
POSTGRES_USER=deskbook
POSTGRES_PASSWORD=deskbook
POSTGRES_DB=deskbook
